{
    "configurations": [
        {
            "name": "ESP-IDF-ESP32S3",
            "compilerPath": "${env:IDF_TOOLS_PATH}/tools/xtensa-esp-elf/esp-15.2.0_20251204/xtensa-esp-elf/bin/xtensa-esp32s3-elf-gcc",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "includePath": [
                "${env:IDF_PATH}/components/**",
                "${env:IDF_PATH}/components/**/include",
                "${workspaceFolder}/main",
                "${workspaceFolder}/build/config",
                "${workspaceFolder}/components/wrapper-esp32/src",
                "${workspaceFolder}/managed_components/**",
                "${workspaceFolder}/managed_components/**/include"
            ],
            "browse": {
                "path": [
                    "${env:IDF_PATH}/components",
                    "${workspaceFolder}/main",
                    "${workspaceFolder}/build/config",
                    "${workspaceFolder}/components/wrapper-esp32/src"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
